  <!-- GUION 05-A -->
  <div class="script-card">
    <div class="sc-header">
      <div class="sc-meta">
        <div class="sc-num">Guion 05-A · Fase 5 · G7Cripto Hoy</div>
        <div class="sc-title">«13 años construyendo lo que tienes en tus manos»</div>
        <div class="sc-desc">Para veteranos — el cierre emocional de la saga. El regreso al origen.</div>
      </div>
      <div class="sc-badges">
        <span class="badge b-amber">Veteranos del gremio</span>
        <span class="duration">⏱ 75–90 seg</span>
