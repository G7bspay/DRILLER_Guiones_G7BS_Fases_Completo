  <!-- GUION 04-C -->
  <div class="script-card">
    <div class="sc-header">
      <div class="sc-meta">
        <div class="sc-num">Guion 04-C · Fase 4 · Transformación</div>
        <div class="sc-title">«G7Fintech SAS — de la intermediación a la infraestructura»</div>
        <div class="sc-desc">Pieza institucional formal. Para presentaciones corporativas y aliados.</div>
      </div>
      <div class="sc-badges">
        <span class="badge b-green">Doble audiencia</span>
